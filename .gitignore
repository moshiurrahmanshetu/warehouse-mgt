# WMS — Git Ignore Rules

# Environment / Config (don't commit credentials)
config/database.php

# Logs
logs/
*.log

# Uploads (user content)
uploads/*
!uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# PHP errors / cache
*.cache

# Setup file (delete after first run)
setup.php
